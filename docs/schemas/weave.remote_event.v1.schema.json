{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/misty-step/weave/blob/master/docs/schemas/weave.remote_event.v1.schema.json",
  "title": "Weave Remote Event v1",
  "description": "Host-neutral event envelope for remote code/work hosts. GitHub, GitLab, Forgejo/Gitea, Gerrit, and future adapters normalize native webhooks into this contract before BB, Cerberus, Landmark, or Canary consume them.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "producer",
    "produced_at",
    "occurred_at",
    "correlation_id",
    "source",
    "repository",
    "subject",
    "actor",
    "action",
    "idempotency_key",
    "host_payload",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "weave.remote_event.v1"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Adapter-generated event id. Stable for one normalized event record."
    },
    "producer": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "version": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "produced_at": {
      "type": "string",
      "format": "date-time",
      "description": "Time the adapter produced this normalized envelope."
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "Best host/native event timestamp. If the host has no event timestamp, use the adapter receipt time and preserve that fact in payload."
    },
    "correlation_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source": {
      "type": "object",
      "required": [
        "kind",
        "host",
        "external_id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "github",
            "gitlab",
            "forgejo",
            "gitea",
            "gerrit",
            "powder",
            "canary",
            "bb",
            "cerberus",
            "crucible",
            "threshold",
            "landmark",
            "harness-kit"
          ]
        },
        "host": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Host name that emitted the native event, for example github.com."
        },
        "external_id": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Host delivery id, event id, hook id, or equivalent native identifier."
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "repository": {
      "type": "object",
      "required": [
        "id",
        "full_name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "full_name": {
          "$ref": "#/$defs/repo_full_name"
        },
        "default_branch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "html_url": {
          "type": "string",
          "format": "uri"
        },
        "api_url": {
          "type": "string",
          "format": "uri"
        },
        "clone_url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "pull_request",
            "push",
            "check_run",
            "workflow_run",
            "deployment",
            "release",
            "issue",
            "comment",
            "change",
            "card",
            "incident",
            "run",
            "benchmark",
            "agent_config"
          ]
        },
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sha": {
          "$ref": "#/$defs/sha"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "required": [
        "id",
        "login"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "login": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "bot",
            "app",
            "system",
            "unknown"
          ]
        }
      },
      "additionalProperties": false
    },
    "action": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Normalized action within the subject kind, for example opened, synchronize, push, completed, success, or published."
    },
    "idempotency_key": {
      "$ref": "#/$defs/non_empty_string",
      "description": "Stable dedupe key chosen by the adapter from host delivery id plus subject/action revision."
    },
    "host_payload": {
      "type": "object",
      "required": [
        "event_name",
        "delivery_id",
        "links"
      ],
      "properties": {
        "event_name": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Native host event name, for example pull_request, push, check_run, workflow_run, deployment_status, release, issues, or issue_comment."
        },
        "delivery_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "api_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "raw_payload_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "rel",
              "href"
            ],
            "properties": {
              "rel": {
                "type": "string",
                "enum": [
                  "html",
                  "api",
                  "diff",
                  "patch",
                  "compare",
                  "commits",
                  "checks",
                  "logs",
                  "delivery",
                  "payload",
                  "release",
                  "workflow_run",
                  "deployment",
                  "status"
                ]
              },
              "href": {
                "type": "string",
                "format": "uri"
              },
              "media_type": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": [
        "merge_policy"
      ],
      "properties": {
        "merge_policy": {
          "type": "string",
          "enum": [
            "agent-mergeable",
            "human-review"
          ]
        },
        "source": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      },
      "additionalProperties": false
    },
    "payload": {
      "type": "object",
      "description": "Adapter-owned normalized details. It may retain selected native ids, labels, refs, SHAs, statuses, or check names, but must not carry secrets, private local paths, or tailnet-only hostnames."
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "repo_full_name": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "sha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{7,64}$"
    }
  },
  "additionalProperties": false
}
